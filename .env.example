# Copy to `.env` (git-ignored) and fill in values before `docker compose --profile standalone up`.
# Document required variable NAMES here, never real secret values (see .standards/security.md).
# `__` maps to `:` for .NET config binding, so LOGTO__ISSUER reads as Logto:Issuer.

# --- Postgres -------------------------------------------------------------
# Bootstrap superuser password for the bundled `db` container (admin / break-glass only).
POSTGRES_PASSWORD=
# Password for the least-privilege `calendar_app` role the app actually connects as
# (ASVS V13.2.2 — see docs/security/postgres-least-privilege.md).
CALENDAR_APP_DB_PASSWORD=
# Password for the bundled Logto's own database role.
LOGTO_DB_PASSWORD=

# Local `dotnet run` outside compose reads the connection string from this variable.
# Point it at a Postgres you control, e.g. `docker compose --profile standalone up -d db`:
# ConnectionStrings__Calendar=Host=localhost;Port=5432;Database=calendar;Username=calendar_app;Password=

# --- Logto (identity provider) -------------------------------------------
# Public OIDC base URLs of the bundled Logto. Defaults target local standalone dev.
# LOGTO_ENDPOINT=http://localhost:3001
# LOGTO_ADMIN_ENDPOINT=http://localhost:3002

# OIDC issuer URL (include the /oidc/ path) — the Authority for both auth schemes.
LOGTO__ISSUER=http://localhost:3001/oidc/
# Calendar API resource indicator — the audience validated on JWT-bearer requests.
LOGTO__AUDIENCE=https://calendar.api

# BFF client (Logto "Traditional Web App"). Create it in the admin console (see docs/auth.md),
# then paste the values here.
LOGTO__WEB__CLIENTID=
LOGTO__WEB__CLIENTSECRET=

# M2M client for the assignee directory (Logto "Machine-to-Machine" with the Management API
# access role). RESOURCE must stay the built-in value below.
LOGTO__MANAGEMENT__ENDPOINT=http://localhost:3001
LOGTO__MANAGEMENT__CLIENTID=
LOGTO__MANAGEMENT__CLIENTSECRET=
LOGTO__MANAGEMENT__RESOURCE=https://default.logto.app/api
