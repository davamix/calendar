# Copy to `.env` (git-ignored) and fill in a value before `docker compose up`.
# Document required variable NAMES here, never real secret values (see .standards/security.md).

# Password for the calendar PostgreSQL database (used by both the `db` and `calendar`
# services in docker-compose.yml).
POSTGRES_PASSWORD=

# Local `dotnet run` (outside compose) reads the DB connection string from this variable.
# Point it at a Postgres you control, e.g. `docker compose up -d db`:
# ConnectionStrings__Calendar=Host=localhost;Port=5432;Database=calendar;Username=calendar;Password=
